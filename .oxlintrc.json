{
    "jsPlugins": ["./.oxlint/oxlint-plugin-no-showmessage.mjs"],
    "rules": {
        "correctness": "error",
        "suspicious": "error",
        "pedantic": "error",
        "perf": "error",
        "style": "error"
    },
    "overrides": [
        {
            "files": ["grammars/**/*.js"],
            "globals": {
                "grammar": "readonly",
                "seq": "readonly",
                "choice": "readonly",
                "repeat": "readonly",
                "repeat1": "readonly",
                "optional": "readonly",
                "prec": "readonly",
                "token": "readonly",
                "field": "readonly",
                "alias": "readonly",
                "LANGUAGE": "readonly",
                "LRULE": "readonly"
            },
            "rules": {
                "no-undef": "error",
                "no-unused-vars": "off",
                "no-useless-escape": "off"
            }
        },
        {
            "files": ["server/src/**/*.ts"],
            "rules": {
                "bgforge-mls/no-showmessage": "error"
            }
        }
    ],
    "ignorePatterns": ["**/node_modules/**", "**/out/**", "**/*.d.ts", "server/src/user-messages.ts"]
}
