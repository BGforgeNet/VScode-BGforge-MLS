{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2022",
        "lib": ["es2022"],
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "rootDir": ".."
    },
    "include": [
        "src/ts-plugin.ts",
        "src/filter-diagnostics.ts"
    ]
}
