{
  "name": "tree-sitter-baf",
  "version": "0.1.0",
  "description": "WeiDU BAF (Infinity Engine script) grammar for tree-sitter",
  "type": "module",
  "license": "",
  "author": {
    "name": "BGforge",
    "email": "dev@bgforge.net",
    "url": "https://bgforge.net/"
  },
  "keywords": [
    "tree-sitter",
    "baf",
    "weidu",
    "infinity-engine"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "src/**",
    "*.wasm",
    "queries/**"
  ],
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build --wasm",
    "generate:types": "pnpm exec dts-tree-sitter . > src/tree-sitter.d.ts && cp src/tree-sitter.d.ts ../../server/src/weidu-baf/tree-sitter.d.ts",
    "test": "../../scripts/test-grammar.sh weidu-baf",
    "lint": "oxlint grammar.js",
    "playground": "tree-sitter playground"
  },
  "devDependencies": {
    "@asgerf/dts-tree-sitter": "^0.21.0"
  }
}
