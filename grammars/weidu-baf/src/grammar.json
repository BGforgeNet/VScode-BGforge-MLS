{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "baf",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "block"
      }
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "if",
          "content": {
            "type": "SYMBOL",
            "name": "if_clause"
          }
        },
        {
          "type": "FIELD",
          "name": "then",
          "content": {
            "type": "SYMBOL",
            "name": "then_clause"
          }
        },
        {
          "type": "PATTERN",
          "value": "[Ee][Nn][Dd]"
        }
      ]
    },
    "if_clause": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[Ii][Ff]"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_condition_item"
          }
        }
      ]
    },
    "_condition_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "or_marker"
        },
        {
          "type": "SYMBOL",
          "name": "condition"
        }
      ]
    },
    "or_marker": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[Oo][Rr]"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "FIELD",
          "name": "count",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "condition": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "!"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "call",
          "content": {
            "type": "SYMBOL",
            "name": "call_expr"
          }
        }
      ]
    },
    "then_clause": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[Tt][Hh][Ee][Nn]"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "response"
          }
        }
      ]
    },
    "response": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[Rr][Ee][Ss][Pp][Oo][Nn][Ss][Ee]"
        },
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "FIELD",
          "name": "weight",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "action"
          }
        }
      ]
    },
    "action": {
      "type": "FIELD",
      "name": "call",
      "content": {
        "type": "SYMBOL",
        "name": "call_expr"
      }
    },
    "call_expr": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "func",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "args",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_argument"
                  }
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "FIELD",
                        "name": "args",
                        "content": {
                          "type": "SYMBOL",
                          "name": "_argument"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_argument": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "call_expr"
        },
        {
          "type": "SYMBOL",
          "name": "point"
        },
        {
          "type": "SYMBOL",
          "name": "object_ref"
        },
        {
          "type": "SYMBOL",
          "name": "tra_ref"
        },
        {
          "type": "SYMBOL",
          "name": "variable_ref"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "tra_ref": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "@"
          },
          {
            "type": "PATTERN",
            "value": "\\d+"
          }
        ]
      }
    },
    "object_ref": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "PATTERN",
          "value": "[A-Za-z0-9_.]+"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "point": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "SYMBOL",
          "name": "_point_coord"
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "SYMBOL",
          "name": "_point_coord"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "_point_coord": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "variable_ref"
        }
      ]
    },
    "variable_ref": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "%"
          },
          {
            "type": "PATTERN",
            "value": "[a-zA-Z_][a-zA-Z0-9_]*"
          },
          {
            "type": "STRING",
            "value": "%"
          }
        ]
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "-?\\d+"
          },
          {
            "type": "PATTERN",
            "value": "0x[0-9a-fA-F]+"
          }
        ]
      }
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "PATTERN",
              "value": "[^\"\\n]*"
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "~"
            },
            {
              "type": "PATTERN",
              "value": "[^~\\n]*"
            },
            {
              "type": "STRING",
              "value": "~"
            }
          ]
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "PATTERN",
            "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}