{
  "name": "tree-sitter-weidu-tp2",
  "version": "0.1.0",
  "description": "WeiDU TP2 grammar for tree-sitter",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "BGforge",
    "email": "dev@bgforge.net",
    "url": "https://bgforge.net/"
  },
  "keywords": [
    "tree-sitter",
    "weidu-tp2",
    "weidu",
    "infinity-engine"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "src/**",
    "*.wasm"
  ],
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build --wasm",
    "generate:types": "pnpm exec dts-tree-sitter . > src/tree-sitter.d.ts && cp src/tree-sitter.d.ts ../../server/src/weidu-tp2/tree-sitter.d.ts",
    "test": "tree-sitter test",
    "lint": "eslint grammar.js",
    "playground": "tree-sitter playground"
  },
  "devDependencies": {
    "@asgerf/dts-tree-sitter": "^0.21.0",
    "eslint": "^9.39.3",
    "globals": "^16.5.0"
  }
}
