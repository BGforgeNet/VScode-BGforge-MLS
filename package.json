{
    "name": "bgforge-mls",
    "displayName": "BGforge MLS",
    "description": "BGforge multilanguage server",
    "version": "2.3.0",
    "author": "BGforge",
    "repository": {
        "type": "git",
        "url": "https://github.com/BGforgeNet/VScode-BGforge-MLS"
    },
    "bugs": {
        "url": "https://github.com/BGforgeNet/VScode-BGforge-MLS/issues"
    },
    "publisher": "BGforge",
    "license": "SEE LICENSE IN LICENSE.txt",
    "keywords": [
        "Fallout",
        "Star-Trek Scripting Language",
        "Infinity Engine",
        "Baldur's Gate",
        "WeiDU"
    ],
    "icon": "resources/bgforge.png",
    "engines": {
        "vscode": "^1.43.0"
    },
    "activationEvents": [
        "workspaceContains:**/*.tssl",
        "workspaceContains:**/*.tbaf",
        "workspaceContains:**/*.td",
        "onLanguage:fallout-ssl",
        "onLanguage:fallout-msg",
        "onLanguage:fallout-worldmap-txt",
        "onLanguage:infinity-2da",
        "onLanguage:weidu-baf",
        "onLanguage:weidu-d",
        "onLanguage:weidu-ssl",
        "onLanguage:weidu-slb",
        "onLanguage:weidu-tp2",
        "onLanguage:weidu-tra"
    ],
    "main": "./client/out/extension",
    "contributes": {
        "languages": [
            {
                "id": "typescript",
                "extensions": [
                    ".tbaf",
                    ".tssl",
                    ".td"
                ]
            },
            {
                "id": "weidu-ssl",
                "aliases": [
                    "WeiDU Stratagems script"
                ],
                "extensions": [
                    ".ssl"
                ],
                "configuration": "./language-configurations/weidu-ssl.language-configuration.json"
            },
            {
                "id": "fallout-ssl",
                "aliases": [
                    "Fallout Star-Trek scripting language"
                ],
                "extensions": [
                    ".ssl",
                    ".h"
                ],
                "configuration": "./language-configurations/fallout-ssl.language-configuration.json"
            },
            {
                "id": "fallout-ssl-tooltip"
            },
            {
                "id": "fallout-scripts-lst",
                "aliases": [
                    "Fallout scripts list"
                ],
                "filenames": [
                    "scripts.lst"
                ]
            },
            {
                "id": "fallout-worldmap-txt",
                "aliases": [
                    "Fallout worldmap"
                ],
                "filenames": [
                    "worldmap.txt"
                ],
                "configuration": "./language-configurations/fallout-worldmap-txt.language-configuration.json"
            },
            {
                "id": "fallout-msg",
                "aliases": [
                    "Fallout message file"
                ],
                "extensions": [
                    ".msg"
                ],
                "configuration": "./language-configurations/fallout-msg.language-configuration.json"
            },
            {
                "id": "weidu-tp2",
                "aliases": [
                    "WeiDU TP2"
                ],
                "extensions": [
                    ".tp2",
                    ".tpa",
                    ".tph",
                    ".tpp"
                ],
                "configuration": "./language-configurations/weidu-tp2.language-configuration.json"
            },
            {
                "id": "weidu-tp2-tooltip"
            },
            {
                "id": "weidu-baf",
                "aliases": [
                    "Infinity Engine script"
                ],
                "extensions": [
                    ".baf"
                ],
                "configuration": "./language-configurations/weidu-baf.language-configuration.json"
            },
            {
                "id": "weidu-baf-tooltip"
            },
            {
                "id": "weidu-d",
                "aliases": [
                    "WeiDU dialog"
                ],
                "extensions": [
                    ".d"
                ],
                "configuration": "./language-configurations/weidu-d.language-configuration.json"
            },
            {
                "id": "weidu-d-tooltip"
            },
            {
                "id": "weidu-slb",
                "aliases": [
                    "WeiDU Stratagems library"
                ],
                "extensions": [
                    ".slb"
                ],
                "configuration": "./language-configurations/weidu-slb.language-configuration.json"
            },
            {
                "id": "weidu-tra",
                "aliases": [
                    "WeiDU translation"
                ],
                "extensions": [
                    ".tra"
                ],
                "configuration": "./language-configurations/weidu-tra.language-configuration.json"
            },
            {
                "id": "bgforge-mls-comment"
            },
            {
                "id": "bgforge-mls-string"
            },
            {
                "id": "bgforge-mls-docstring"
            },
            {
                "id": "infinity-2da",
                "aliases": [
                    "Infinity Engine 2DA table"
                ],
                "extensions": [
                    ".2da"
                ],
                "configuration": "./language-configurations/infinity-2da.language-configuration.json"
            }
        ],
        "configurationDefaults": {
            "[fallout-ssl]": {
                "editor.quickSuggestions": {
                    "comments": "on"
                }
            },
            "[weidu-tp2]": {
                "editor.quickSuggestions": {
                    "comments": "on"
                }
            }
        },
        "commands": [
            {
                "command": "extension.bgforge.compile",
                "title": "BGforge MLS: compile"
            },
            {
                "command": "extension.bgforge.dialogPreview",
                "title": "BGforge MLS: Dialog Preview",
                "icon": "$(open-preview)"
            },
            {
                "command": "extension.bgforge.dDialogPreview",
                "title": "BGforge MLS: D Dialog Preview",
                "icon": "$(open-preview)"
            }
        ],
        "customEditors": [
            {
                "viewType": "bgforge.binaryViewer",
                "displayName": "BGforge Binary Viewer",
                "selector": [
                    {
                        "filenamePattern": "*.pro"
                    }
                ],
                "priority": "default"
            }
        ],
        "grammars": [
            {
                "language": "weidu-ssl",
                "scopeName": "source.weidu-ssl",
                "path": "./syntaxes/weidu-ssl.tmLanguage.json"
            },
            {
                "language": "fallout-ssl",
                "scopeName": "source.fallout-ssl",
                "path": "./syntaxes/fallout-ssl.tmLanguage.json"
            },
            {
                "language": "fallout-ssl-tooltip",
                "scopeName": "source.fallout-ssl-tooltip",
                "path": "./syntaxes/fallout-ssl-tooltip.tmLanguage.json"
            },
            {
                "language": "fallout-msg",
                "scopeName": "source.fallout-msg",
                "path": "./syntaxes/fallout-msg.tmLanguage.json"
            },
            {
                "language": "fallout-scripts-lst",
                "scopeName": "source.fallout-scripts-lst",
                "path": "./syntaxes/fallout-scripts-lst.tmLanguage.json"
            },
            {
                "language": "fallout-worldmap-txt",
                "scopeName": "source.fallout-worldmap-txt",
                "path": "./syntaxes/fallout-worldmap-txt.tmLanguage.json"
            },
            {
                "language": "weidu-tp2",
                "scopeName": "source.weidu-tp2",
                "path": "./syntaxes/weidu-tp2.tmLanguage.json"
            },
            {
                "language": "weidu-tp2-tooltip",
                "scopeName": "source.weidu-tp2-tooltip",
                "path": "./syntaxes/weidu-tp2-tooltip.tmLanguage.json"
            },
            {
                "language": "weidu-baf",
                "scopeName": "source.weidu-baf",
                "path": "./syntaxes/weidu-baf.tmLanguage.json"
            },
            {
                "language": "weidu-baf-tooltip",
                "scopeName": "source.weidu-baf-tooltip",
                "path": "./syntaxes/weidu-baf-tooltip.tmLanguage.json"
            },
            {
                "language": "weidu-d",
                "scopeName": "source.weidu-d",
                "path": "./syntaxes/weidu-d.tmLanguage.json"
            },
            {
                "language": "weidu-d-tooltip",
                "scopeName": "source.weidu-d-tooltip",
                "path": "./syntaxes/weidu-d-tooltip.tmLanguage.json"
            },
            {
                "language": "weidu-slb",
                "scopeName": "source.weidu-slb",
                "path": "./syntaxes/weidu-slb.tmLanguage.json"
            },
            {
                "language": "weidu-tra",
                "scopeName": "source.weidu-tra",
                "path": "./syntaxes/weidu-tra.tmLanguage.json"
            },
            {
                "language": "bgforge-mls-comment",
                "scopeName": "source.bgforge-mls-comment",
                "path": "./syntaxes/bgforge-mls-comment.tmLanguage.json"
            },
            {
                "language": "bgforge-mls-string",
                "scopeName": "source.bgforge-mls-string",
                "path": "./syntaxes/bgforge-mls-string.tmLanguage.json"
            },
            {
                "language": "bgforge-mls-docstring",
                "scopeName": "source.bgforge-mls-docstring",
                "path": "./syntaxes/bgforge-mls-docstring.tmLanguage.json"
            },
            {
                "language": "infinity-2da",
                "scopeName": "source.infinity-2da",
                "path": "./syntaxes/infinity-2da.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "fallout-ssl",
                "path": "./snippets/fallout-ssl.json"
            },
            {
                "language": "weidu-baf",
                "path": "./snippets/weidu-baf.json"
            },
            {
                "language": "weidu-tp2",
                "path": "./snippets/weidu-tp2.json"
            }
        ],
        "themes": [
            {
                "label": "BGforge Monokai",
                "uiTheme": "vs-dark",
                "path": "./themes/bgforge-monokai.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "BGforge MLS",
            "properties": {
                "bgforge.falloutSSL.useBuiltInCompiler": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use built-in compiler instead of external compile.exe"
                },
                "bgforge.falloutSSL.compilePath": {
                    "type": "string",
                    "default": "wine ~/bin/compile",
                    "description": "Path to compile.exe from sfall modders pack. Alternatively, you can add compile.exe to system PATH and leave default here. Ignored if 'Use built-in compiler' is enabled."
                },
                "bgforge.falloutSSL.compileOptions": {
                    "type": "string",
                    "default": "-q -p -l -O2 -d -s -n",
                    "description": "Compilation options for compile.exe from sfall modders pack."
                },
                "bgforge.falloutSSL.outputDirectory": {
                    "type": "string",
                    "default": "",
                    "description": "Where to put the compiled Fallout SSL scripts, absolute path. Default is to put compiled scripts next to the source file.\nYou'll probably want to set this to data/scripts of your Fallout 2 game directory."
                },
                "bgforge.falloutSSL.headersDirectory": {
                    "type": "string",
                    "default": "",
                    "description": "Path to an additional directory with Fallout headers to scan for defines.\nLeave empty if all your headers are inside workspace directory. Workspace is always scanned."
                },
                "bgforge.weidu.path": {
                    "type": "string",
                    "default": "weidu",
                    "description": "Path to WeiDU binary. Alternatively, you can add WeiDU to system PATH and leave default here."
                },
                "bgforge.weidu.gamePath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to an IE game. Needed to use parse feature on BAF and D files."
                },
                "bgforge.validateOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run and show diagnostics when saving files."
                },
                "bgforge.validateOnChange": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Run and show diagnostics repeatedly as you edit the files.\n\n**Note:** this can be disk intensive, as validation requires files to be saved to disk."
                }
            }
        },
        "keybindings": [
            {
                "command": "extension.bgforge.compile",
                "key": "ctrl+r"
            },
            {
                "command": "extension.bgforge.dialogPreview",
                "key": "ctrl+shift+v",
                "when": "editorLangId == fallout-ssl"
            },
            {
                "command": "extension.bgforge.dDialogPreview",
                "key": "ctrl+shift+v",
                "when": "editorLangId == weidu-d || resourceExtname == .td"
            }
        ],
        "typescriptServerPlugins": [
            {
                "name": "bgforge-tssl-plugin"
            },
            {
                "name": "bgforge-td-plugin"
            }
        ],
        "iconThemes": [
            {
                "id": "bgforge",
                "label": "BGforge",
                "path": "./themes/bgforge-icon-theme.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "./scripts/prepublish.sh",
        "build": "pnpm build:client && pnpm build:server && pnpm build:test && pnpm build:webviews",
        "build:dev": "./scripts/build-dev.sh",
        "build:all": "pnpm build:grammar && pnpm build",
        "build:ts-plugin": "./scripts/build-ts-plugin.sh",
        "build:td-plugin": "./scripts/build-td-plugin.sh",
        "build:client": "pnpm build:base:client --sourcemap && pnpm build:ts-plugin --sourcemap && pnpm build:td-plugin --sourcemap && pnpm build:bin-cli",
        "build:server": "pnpm build:base:server --sourcemap && pnpm lint:cli && pnpm build:format-cli && pnpm build:transpile-cli",
        "build:webviews": "pnpm build:base:webviews --sourcemap",
        "build:test": "./scripts/build-test.sh",
        "build:format-cli": "./scripts/build-format-cli.sh",
        "build:transpile-cli": "./scripts/build-transpile-cli.sh",
        "build:bin-cli": "./scripts/build-bin-cli.sh",
        "build:grammar": "bash ./scripts/build-grammar.sh",
        "build:base:client": "./scripts/build-base-client.sh",
        "build:base:server": "bash ./scripts/build-base-server.sh",
        "build:base:webviews": "./scripts/build-base-webviews.sh",
        "watch:client": "pnpm build:base:client --sourcemap --watch",
        "watch:server": "pnpm build:base:server --sourcemap --watch",
        "test": "./scripts/test.sh",
        "test:all": "pnpm test && pnpm test:grammars && pnpm test:format-samples && pnpm test:e2e",
        "test:client": "cd client && pnpm test",
        "test:server": "cd server && pnpm test",
        "test:grammars": "./scripts/test-grammars.sh",
        "test:external": "./scripts/test-external.sh",
        "test:grammar": "./scripts/test-grammar.sh",
        "regenerate-expected": "./scripts/regenerate-expected.sh",
        "test:format-samples": "./scripts/test-format-samples.sh",
        "test:cli": "vitest run --config cli/vitest.config.ts",
        "test:bin": "./scripts/test-bin.sh",
        "test:e2e": "./scripts/test-e2e.sh",
        "test:coverage": "cd server && vitest run --coverage",
        "package": "pnpm vsce package --no-dependencies",
        "format": "node --no-warnings cli/format/out/format-cli.js",
        "format-samples": "./scripts/format-samples.sh",
        "transpile": "node --no-warnings cli/transpile/out/transpile-cli.js",
        "bin": "node cli/bin/out/bin-cli.js",
        "lint:cli": "./scripts/lint-cli.sh",
        "ie-update": "./scripts/ie-update.sh",
        "fallout-update": "./scripts/fallout-update.sh",
        "generate-data": "./scripts/generate-data.sh",
        "syntaxes-to-json": "./scripts/syntaxes-to-json.sh",
        "update-data": "pnpm ie-update && pnpm fallout-update && pnpm generate-data && pnpm syntaxes-to-json",
        "test:scripts": "vitest run --config scripts/vitest.config.ts",
        "lint:scripts": "./scripts/lint-scripts.sh",
        "knip": "knip"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.17.1",
        "@typescript-eslint/eslint-plugin": "^8.39.1",
        "@typescript-eslint/parser": "^8.39.1",
        "@vitest/coverage-v8": "^4.0.18",
        "@vscode/codicons": "^0.0.44",
        "@vscode/vsce": "^3.3.2",
        "esbuild": "^0.25.8",
        "eslint": "^9.33.0",
        "globals": "^15.15.0",
        "knip": "^5.79.0",
        "mocha": "^11.7.1",
        "prettier": "^3.6.2",
        "tree-sitter-cli": "0.26.3",
        "tsx": "^4.21.0",
        "typescript": "^5.7.3",
        "vitest": "^4.0.18",
        "yaml": "^2.8.2"
    },
    "categories": [
        "Programming Languages"
    ],
    "homepage": "https://forums.bgforge.net/viewforum.php?f=35",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "tree-sitter-cli"
        ]
    }
}