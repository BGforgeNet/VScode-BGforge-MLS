/**
 * TypeScript configuration for fallout-update scripts.
 * Standalone config for one-shot data update scripts (not part of the main build).
 */
{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["es2022"],
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "outDir": "out",
        "rootDir": "src",
        "sourceMap": true,
        "noEmit": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "out", "test"]
}
