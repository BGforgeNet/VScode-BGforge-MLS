<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE language>
<!--
  KSyntaxHighlighting definition for Fallout scripts.lst files.
  Hand-written (not generated) because scripts.lst is a simple line-based
  format: scriptname.int ;description # local_vars=N
  Install to: ~/.local/share/org.kde.syntax-highlighting/syntax/
-->
<language name="Fallout scripts.lst" version="1" kateversion="5.0" section="Scripts"
          extensions="scripts.lst" casesensitive="true"
          author="BGforge" license="MIT">
  <highlighting>
    <contexts>
      <context name="Normal" attribute="Normal" lineEndContext="#stay">
        <!-- Comment: ; to end of line -->
        <DetectChar attribute="Comment" context="Comment" char=";"/>
        <!-- Directive: # local_vars=N -->
        <DetectChar attribute="Keyword" context="Directive" char="#"/>
        <!-- Script filename: word.int -->
        <RegExpr attribute="Variable" String="\b\w+(?=\.int\b)" context="#stay"/>
        <StringDetect attribute="Extension" String=".int" context="#stay"/>
      </context>

      <context name="Comment" attribute="Comment" lineEndContext="#pop">
        <!-- # inside comment starts directive -->
        <DetectChar attribute="Keyword" context="Directive" char="#"/>
      </context>

      <context name="Directive" attribute="Keyword" lineEndContext="#pop#pop">
        <RegExpr attribute="Variable" String="\blocal_vars\b" context="#stay"/>
        <DetectChar attribute="Keyword" context="#stay" char="="/>
        <RegExpr attribute="Number" String="\b\d+\b" context="#stay"/>
      </context>
    </contexts>

    <itemDatas>
      <itemData name="Normal" defStyleNum="dsNormal"/>
      <itemData name="Variable" defStyleNum="dsVariable"/>
      <itemData name="Extension" defStyleNum="dsString"/>
      <itemData name="Comment" defStyleNum="dsComment"/>
      <itemData name="Keyword" defStyleNum="dsKeyword"/>
      <itemData name="Number" defStyleNum="dsDecVal"/>
    </itemDatas>
  </highlighting>

  <general>
    <keywords casesensitive="true"/>
  </general>
</language>
