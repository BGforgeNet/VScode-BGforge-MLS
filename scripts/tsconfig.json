/**
 * TypeScript configuration for all data update scripts.
 * Standalone config (not part of the main build).
 */
{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["es2022"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "skipLibCheck": true,
        "outDir": "out",
        "sourceMap": true,
        "noEmit": true,
        "tsBuildInfoFile": "../tmp/scripts.tsbuildinfo"
    },
    "include": [
        "ie-update/src",
        "ie-update/test",
        "fallout-update/src",
        "fallout-update/test",
        "utils/src",
        "utils/test"
    ],
    "exclude": ["node_modules", "out"]
}
