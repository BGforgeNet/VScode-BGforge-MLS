{
    "name": "@bgforge/mls-server",
    "description": "LSP server for Fallout SSL, WeiDU (BAF/D/TP2), and related modding languages",
    "version": "3.1.0",
    "author": "BGforge",
    "license": "SEE LICENSE IN LICENSE.txt",
    "main": "out/server.js",
    "bin": {
        "bgforge-mls-server": "out/server.js"
    },
    "files": [
