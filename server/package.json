        "url": "https://github.com/BGforgeNet/VScode-BGforge-MLS",
        "directory": "server"
    },
    "homepage": "https://github.com/BGforgeNet/VScode-BGforge-MLS",
    "bugs": {
        "url": "https://github.com/BGforgeNet/VScode-BGforge-MLS/issues"
