{
    "compilerOptions": {
        "skipLibCheck": true,
        "target": "es2022",
        "lib": [
            "es2022"
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "sourceMap": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "outDir": "out",
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test",
        "test"
    ]
}