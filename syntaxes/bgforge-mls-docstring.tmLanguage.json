{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BGforge MLS docstring",
  "scopeName": "source.bgforge-mls-docstring",
  "patterns": [
    {
      "include": "#param"
    },
    {
      "include": "#ret"
    },
    {
      "include": "#typeTag"
    },
    {
      "include": "#deprecated"
    },
    {
      "include": "#comment"
    }
  ],
  "repository": {
    "param": {
      "patterns": [
        {
          "match": "(@arg|@param)(\\s+\\{(\\w+)\\})\\s+((\\w+)(!)?)",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "comment.bgforge-mls-docstring",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            },
            "4": {
              "name": "variable.bgforge-mls-docstring"
            },
            "6": {
              "name": "invalid"
            }
          }
        },
        {
          "match": "(@arg|@param)(\\s+\\{(\\w+)\\})\\s+(\\[(\\w+)=([^\\]]+)\\])",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "comment.bgforge-mls-docstring",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            },
            "4": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "5": {
              "name": "variable.bgforge-mls-docstring"
            },
            "6": {
              "name": "variable.bgforge-mls-docstring"
            }
          }
        },
        {
          "match": "(@arg|@param)(\\s+\\{(\\w+)\\})",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "comment.bgforge-mls-docstring",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            }
          }
        },
        {
          "match": "(@arg|@param)\\s+(array|any|bool|filename|float|ids|int|list|map|mixed|ObjectPtr|resref|string)\\s+(\\w+)(!)?",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "support.type.bgforge-mls-docstring"
            },
            "3": {
              "name": "variable.bgforge-mls-docstring"
            },
            "4": {
              "name": "invalid"
            }
          }
        },
        {
          "match": "(@arg|@param)\\s+(array|any|bool|filename|float|ids|int|list|map|mixed|ObjectPtr|resref|string)\\b",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "support.type.bgforge-mls-docstring"
            }
          }
        },
        {
          "match": "(@arg|@param)\\b",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            }
          }
        }
      ]
    },
    "ret": {
      "patterns": [
        {
          "match": "(@ret|@return|@returns)(\\s+\\{(\\w+)\\})\\s+((\\w+))",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "comment.bgforge-mls-docstring",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            },
            "5": {
              "name": "variable.bgforge-mls-docstring"
            }
          }
        },
        {
          "match": "(@ret|@return|@returns)(\\s+\\{(\\w+)\\})",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "comment.bgforge-mls-docstring",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            }
          }
        },
        {
          "match": "(@ret|@return|@returns)\\s+(array|any|bool|filename|float|ids|int|list|map|mixed|ObjectPtr|resref|string)\\s+(\\w+)",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "support.type.bgforge-mls-docstring"
            },
            "3": {
              "name": "variable.bgforge-mls-docstring"
            }
          }
        },
        {
          "match": "(@ret|@return|@returns)\\s+(array|any|bool|filename|float|ids|int|list|map|mixed|ObjectPtr|resref|string)\\b",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "support.type.bgforge-mls-docstring"
            }
          }
        },
        {
          "match": "(@ret|@return|@returns)\\b",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            }
          }
        }
      ]
    },
    "deprecated": {
      "patterns": [
        {
          "match": "(@deprecated)",
          "name": "support.function.bgforge-mls-docstring"
        }
      ]
    },
    "typeTag": {
      "patterns": [
        {
          "match": "(@type)(\\s+{?(\\w+)}?)?",
          "captures": {
            "1": {
              "name": "support.function.bgforge-mls-docstring"
            },
            "2": {
              "name": "keyword.bgforge-mls-docstring"
            },
            "3": {
              "name": "support.type.bgforge-mls-docstring"
            }
          }
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "match": "\\b(array|any|bool|filename|float|ids|int|list|map|mixed|ObjectPtr|resref|string)\\b",
          "name": "support.type.bgforge-mls-docstring"
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "match": ".",
          "name": "comment.bgforge-mls-docstring"
        }
      ]
    }
  }
}